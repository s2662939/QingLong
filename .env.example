# =============================================================================
# A009 青龙面板 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# =============================================================================

# WxPusher 微信推送
WXPUSHER_APP_TOKEN=AT_xxxxxxxxxx
WXPUSHER_UID=UID_xxxxxxxxxx

# 群晖 NAS 配置
SYNOLOGY_USERNAME=admin
SYNOLOGY_PASSWORD=your_password

# 邮件通知配置
SMTP_SERVICE=smtp.qq.com
SMTP_EMAIL=your_email@qq.com
SMTP_PASSWORD=your授权码
SMTP_EMAIL_TO=recipient@example.com
SMTP_NAME=文件管理系统

# MariaDB 数据库密码
# 用于青龙面板连接 MariaDB 10
MARIADB_ROOT_PASSWORD=your_mariadb_password

# MariaDB 主机地址
# 填群晖NAS的局域网IP地址
MARIADB_HOST=192.168.1.100
